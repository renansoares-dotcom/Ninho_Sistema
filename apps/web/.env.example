# Copie este arquivo para .env.local e preencha com os valores do seu projeto Supabase
# Painel Supabase > Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL pública do site (usada no link de "esqueci minha senha"). Em dev local
# pode deixar em branco — cai no fallback http://localhost:3000.
NEXT_PUBLIC_SITE_URL=

# Service role key do Supabase (Project Settings > API > service_role).
# NUNCA prefixar com NEXT_PUBLIC_ — essa chave ignora todo o RLS e só pode
# ser usada em código de servidor (Diagnóstico Público, cron de automações,
# notificação de mensagem por e-mail).
SUPABASE_SERVICE_ROLE_KEY=

# Segredo usado pelo Vercel Cron pra chamar /api/cron/automacoes com
# segurança (qualquer texto longo e aleatório serve).
CRON_SECRET=

# Envio de e-mail (Resend — resend.com). Sem isso configurado, o app
# continua funcionando normal, só não manda e-mail nenhum.
RESEND_API_KEY=
# Formato: "Nome <email@seudominio.com>". Pra testar sem verificar domínio
# próprio, pode deixar em branco — usa o remetente de teste do Resend.
EMAIL_REMETENTE=
