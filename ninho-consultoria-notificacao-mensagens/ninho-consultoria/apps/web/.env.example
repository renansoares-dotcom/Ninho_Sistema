# Copie este arquivo para .env.local e preencha com os valores do seu projeto Supabase
# Painel Supabase > Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL pública do site (usada no link de "esqueci minha senha"). Em dev local
# pode deixar em branco — cai no fallback http://localhost:3000.
NEXT_PUBLIC_SITE_URL=
